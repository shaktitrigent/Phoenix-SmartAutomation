# Environment variables for {{ project_name }}
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

APP_URL={{ base_url }}
TEST_USERNAME=your_username_here
TEST_PASSWORD=your_password_here

PHOENIX_BROWSER={{ browser }}
PHOENIX_LOG_LEVEL=INFO
ANTHROPIC_API_KEY=your_api_key_here

# ---------------------------------------------------------------------------
# Jira integration (optional)
# Get your API token at: https://id.atlassian.com/manage-profile/security/api-tokens
# Also enable [jira] section in .phoenixrc with your instance URL and project key.
# ---------------------------------------------------------------------------
# JIRA_URL=https://yourcompany.atlassian.net
# JIRA_EMAIL=your.email@company.com
# JIRA_API_TOKEN=your_jira_api_token_here
