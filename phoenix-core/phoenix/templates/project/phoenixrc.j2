# Phoenix project configuration — generated by phoenix init
# https://github.com/your-org/Phoenix-SmartAutomation

[project]
name             = "{{ project_name }}"
base_url         = "{{ base_url }}"
default_browser  = "{{ browser }}"
layout           = "pom-v1"
bdd              = {{ 'true' if bdd else 'false' }}

[input]
source      = "user_stories"
stories_dir = "./user_stories"

[llm]
provider       = "anthropic"
model          = "claude-sonnet-4-6"
fallback_model = "claude-haiku-4-5-20251001"

[intelligence]
base_url    = "http://localhost:8001/api/v1"
timeout     = 300
retry_count = 3

[healing]
enabled      = true
max_attempts = 3

[run]
viewport_width  = 1920
viewport_height = 1080

[test_data]
strategy           = "generated"
locale             = "en_US"
include_edge_cases = true

[reporting]
format     = "html"
output_dir = "./reports"

# ---------------------------------------------------------------------------
# Page Object Model settings (pom-v1 layout)
# ---------------------------------------------------------------------------
[pom]
pages_dir       = "./pages"
utils_dir       = "./utils"
manifest_file   = ".phoenix/manifest.json"

{% if bdd %}
# ---------------------------------------------------------------------------
# BDD / keyword-driven settings
# ---------------------------------------------------------------------------
[bdd]
features_dir   = "./features"
steps_dir      = "./steps"
keywords_file  = ".phoenix/keywords.json"
auto_heal_threshold = 0.85
ask_threshold       = 0.55

{% endif %}
# ---------------------------------------------------------------------------
# Jira integration (optional — remove the # to enable)
# Secrets must be set as environment variables, never in this file:
#   JIRA_URL=https://yourcompany.atlassian.net
#   JIRA_EMAIL=your.email@company.com
#   JIRA_API_TOKEN=your_api_token_here
