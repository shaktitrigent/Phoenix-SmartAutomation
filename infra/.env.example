# Copy this file to .env and fill in the values
# Never commit .env to source control

# ---- Required ----
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- LLM Settings ----
PHOENIX_LLM_PROVIDER=anthropic
PHOENIX_LLM_MODEL=claude-sonnet-4-20250514
PHOENIX_LLM_MAX_TOKENS=4096
PHOENIX_LLM_TEMPERATURE=0.2

# ---- Optional: OpenAI fallback ----
# OPENAI_API_KEY=sk-your-openai-key
# PHOENIX_LLM_PROVIDER=openai
# PHOENIX_LLM_MODEL=gpt-4o

# ---- Optional: Gemini fallback ----
# GOOGLE_API_KEY=your-gemini-key
# PHOENIX_LLM_PROVIDER=gemini
# PHOENIX_LLM_MODEL=gemini-1.5-pro

# ---- Intelligence Server ----
PHOENIX_INTELLIGENCE_HOST=0.0.0.0
PHOENIX_INTELLIGENCE_PORT=8001
PHOENIX_INTELLIGENCE_LOG_LEVEL=info

# ---- MCP Settings ----
PHOENIX_MCP_ENABLED=true
PHOENIX_MCP_COMMAND=npx
PHOENIX_MCP_ARGS=@playwright/mcp@latest --headless
PHOENIX_MCP_TIMEOUT=30
