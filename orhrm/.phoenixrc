# Phoenix project configuration — generated by phoenix init
# https://github.com/your-org/Phoenix-SmartAutomation

[project]
default_project    = "orhrm"
application_url    = "https://opensource-demo.orangehrmlive.com/web/index.php/auth/login"
manual_output_dir  = "./manual_tests"
test_output_dir    = "./test_results"
report_output_dir  = "./reports"

[intelligence]
base_url    = "http://localhost:8001/api/v1"
timeout     = 300
retry_count = 3

[database]
url = "sqlite:///./phoenix.db"

[execution]
default_browser  = "chromium"
headless         = true
screenshot_on_failure = true
