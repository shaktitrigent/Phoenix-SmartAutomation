# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# Test / IDE caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Runtime artifacts that belong in a consumer project, not here
# NOTE: tests/ is intentionally NOT excluded here because phoenix-core/tests/ contains
# the framework's own unit tests (source code). Consumer-project generated test scripts
# live in the consumer's tests/ folder, which is excluded by the root .gitignore.
locators/
logs/
manual_tests/
test_data/
reports/
user_stories/
fixtures/
config/
*.db
*.db-shm
*.db-wal

# Consumer project config files (generated by phoenix init)
.phoenixrc
phoenix.yaml
config.yaml
.env
.env.local

# OS noise
.DS_Store
Thumbs.db
